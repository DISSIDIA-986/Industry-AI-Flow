        <mxCell id="wf-note1-e" style="rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=none;strokeColor=#92400E;strokeWidth=1;dashed=1;" edge="1" parent="1" source="wf-note1" target="wf-n5">
          <mxGeometry relative="1" as="geometry"/>
