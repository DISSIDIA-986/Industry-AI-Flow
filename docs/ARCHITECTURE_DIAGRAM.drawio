          <mxGeometry x="1040" y="200" width="150" height="60" as="geometry"/>
        </mxCell>

        <!-- Node 7: route_node -->
        <mxCell id="wf-n7" value="&lt;b&gt;⑦ route_node&lt;/b&gt;&lt;br&gt;LLM Dispatch" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#8B5CF6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1240" y="200" width="150" height="60" as="geometry"/>
        </mxCell>

        <!-- Node 8: code_exec_node -->
        <mxCell id="wf-n8" value="&lt;b&gt;⑧ code_exec_node&lt;/b&gt;&lt;br&gt;Sandboxed Execution" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D1FAE5;strokeColor=#059669;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1440" y="200" width="150" height="60" as="geometry"/>
        </mxCell>

        <!-- Node 9: safety_node -->
