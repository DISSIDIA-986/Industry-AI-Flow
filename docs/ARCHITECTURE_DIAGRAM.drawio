          <mxGeometry x="440" y="200" width="150" height="60" as="geometry"/>
        </mxCell>

        <!-- Node 4: rerank_node -->
        <mxCell id="wf-n4" value="&lt;b&gt;④ rerank_node&lt;/b&gt;&lt;br&gt;BGE Reranker" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#3B82F6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="640" y="200" width="150" height="60" as="geometry"/>
