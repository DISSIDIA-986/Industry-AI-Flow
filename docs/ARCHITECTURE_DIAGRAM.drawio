          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="wf-e7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#8B5CF6;strokeWidth=2;" edge="1" parent="1" source="wf-n7" target="wf-n8">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
