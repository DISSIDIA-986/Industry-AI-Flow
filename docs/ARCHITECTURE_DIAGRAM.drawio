          <mxGeometry x="40" y="200" width="150" height="60" as="geometry"/>
        </mxCell>

        <!-- Node 2: cost_estimation_node -->
        <mxCell id="wf-n2" value="&lt;b&gt;② cost_estimation&lt;br&gt;_node&lt;/b&gt;&lt;br&gt;ML Cost Prediction" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#8B5CF6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="240" y="200" width="150" height="60" as="geometry"/>
        </mxCell>

