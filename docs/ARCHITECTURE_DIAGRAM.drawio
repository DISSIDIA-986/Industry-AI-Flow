          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="wf-e9" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#DC2626;strokeWidth=2;" edge="1" parent="1" source="wf-n9" target="wf-n10">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Shortcut: cost_estimation_node -> safety_node (dashed) -->
        <mxCell id="wf-shortcut" value="shortcut_response" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#DC2626;strokeWidth=1;dashed=1;dashPattern=8 4;exitX=0.5;exitY=1;entryX=0.5;entryY=1;" edge="1" parent="1" source="wf-n2" target="wf-n9">
          <mxGeometry relative="1" as="geometry">
