.env
.env.*
!.env.example
.env.local
.env.local.*
.venv/
.venv_*/
.venv-*/
venv/
venv_*/
venv-*/
env/
test_env/

# ==========================================
# Python bytecode and caches
# ==========================================
__pycache__/
*.py[cod]
*$py.class
.Python
*.pyc

