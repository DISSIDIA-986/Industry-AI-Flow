# ==========================================
# Environment and virtual environments
# ==========================================
.env
.env.*
!.env.example
.venv/
.venv_capstone/
.venv_test/
venv/
venv_*/
venv_test/
env/
test_env/

# ==========================================
# Python bytecode and caches
# ==========================================
__pycache__/
*.py[cod]
*$py.class
.Python

# ==========================================
# Build and packaging artifacts
# ==========================================
build/
dist/
downloads/
eggs/
.eggs/
sdist/
wheels/
pip-wheel-metadata/
*.egg-info/
*.egg

# ==========================================
# Test, lint, and coverage artifacts
# ==========================================
.pytest_cache/
.mypy_cache/
.ruff_cache/
.cache/
.tox/
.nox/
.hypothesis/
.dmypy.json
dmypy.json
.coverage
.coverage.*
coverage.xml
htmlcov/

# ==========================================
# Logs and temp outputs
# ==========================================
logs/
*.log
*.out
*.err
temp/
tmp/
*.tmp
*.temp
*.pid
*.pid.lock
output/
outputs/
test_output/
reports/
benchmark_results/
performance_logs/

# ==========================================
# Documentation build outputs
# ==========================================
docs/_build/
docs/site/
site/

# ==========================================
# Data stores and local runtime caches
# ==========================================
*.db
*.sqlite
*.sqlite3
vector_db/
embeddings/
cache/

# ==========================================
# Workspace generated artifacts
# ==========================================
workspace/models/
workspace/experiments/*
workspace/prototypes/*
workspace/sandbox/*
!workspace/experiments/.gitkeep
!workspace/prototypes/.gitkeep
!workspace/sandbox/.gitkeep

# ==========================================
# Frontend local dependencies
# ==========================================
frontend/node_modules/

# ==========================================
