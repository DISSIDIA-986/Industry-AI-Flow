**/junit-results.xml
**/playwright-report/
**/playwright-results.json
**/test-results/
**/test-output/
**/test-reports/
CODE_REVIEW_RESULTS.json

# ==========================================
# Logs and temp outputs
# ==========================================
logs/
*.log
*.out
*.err
temp/
tmp/
*.tmp
*.temp
*.pid
*.pid.lock
output/
outputs/
test_output/
reports/
benchmark_results/
performance_logs/
startup_debug.log
cleanup_manifest.log

# ==========================================
# Documentation build outputs
# ==========================================
docs/_build/
docs/site/
site/

# ==========================================
# Data stores and local runtime caches
# ==========================================
*.db
*.sqlite
*.sqlite3
vector_db/
embeddings/
cache/

# ==========================================
# Workspace generated artifacts
# ==========================================
workspace/models/
workspace/experiments/*
workspace/prototypes/*
workspace/sandbox/*
!workspace/experiments/.gitkeep
!workspace/prototypes/.gitkeep
!workspace/sandbox/.gitkeep

# ==========================================
# Frontend local dependencies and build artifacts
# ==========================================
frontend/node_modules/
frontend/.next/
frontend/.turbo/
frontend/nextjs/node_modules/
frontend/nextjs/.next/
frontend/nextjs/.turbo/

# Allow repository runbooks even if user-level global gitignore ignores docs/
!docs/
!docs/runbooks/
!docs/runbooks/*.md
!docs/development/
!docs/development/status/
!docs/development/status/*.md
!docs/development/status/active/
!docs/development/status/active/*.md
!docs/development/status/archive/
!docs/development/status/archive/*.md
!docs/development/analysis/
!docs/development/analysis/*.md
!docs/development/plans/
!docs/development/plans/*.md
!docs/reports/
!docs/reports/*.md
!docs/reports/**/*.md
!.deprecated/
!.deprecated/reports/
!.deprecated/reports/auto/
!.deprecated/reports/auto/*.md
!.deprecated/frontend-legacy/
!.deprecated/frontend-legacy/**
# Monorepo-safe catch-all for nested app packages
**/node_modules/
**/.next/
**/.turbo/

# ==========================================
# Python package management artifacts
# ==========================================
pip-log.txt
pip-delete-this-directory.txt

# ==========================================
# Frontend package manager logs
# ==========================================
yarn-error.log
pnpm-debug.log
npm-debug.log*

# ==========================================
# Editor and OS files
# ==========================================
.vscode/
.idea/
*.swp
*.swo
*~
*.orig
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db

# ==========================================
# Notebook checkpoints
# ==========================================
.ipynb_checkpoints/

# ==========================================
# Cleanup / audit artifacts
# ==========================================
cleanup_manifest.log
cleanup_scan_report.tsv
.claude/

# ==========================================
# Legacy local-only directories
# ==========================================
samples/
chinese_docker_output/
chinese_visualization_output/

# Keep dependency specs and demo fixture files tracked
!requirements/
!requirements/**/*.txt
!test_resources/demo/
!test_resources/demo/**/*.json

# Keep Claude skill/command markdown files tracked even with global '*.md' ignore rules.
!claude/commands/*.md
!claude/skills/**/SKILL.md

# Large model files
models/**/*.gguf
models/**/*.bin
models/**/*.safetensors

# Dogfood testing output (screenshots, videos, reports)
dogfood-output/

# Large binary documents — RAG seed docs kept on disk, not in git
test_resources/documents/**/*.pdf
test_resources/documents/**/*.doc
test_resources/documents/**/*.docx
test_resources/documents/**/*.zip
test_resources/documents/**/*.rar
test_resources/documents/**/*.7z

# Model cache
models/**/.cache/
# Allow Claude agent skills documentation
!claude/*.md

# Claude Code local agent skills (project-specific tooling)
.agents/

# Backup CSV files
docs/testing/*_backup*.csv
docs/testing/*_old_backup*.csv

# Binary presentation files (share via cloud storage)
docs/presentation/*.pptx

# Frontend node modules
frontend/nextjs/node_modules/
.gstack/
