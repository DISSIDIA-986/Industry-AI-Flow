# Ensure research markdown files are tracked
!research/*.md

# Deprecated files (kept for reference, not scanned)
docs/deprecated/

# Cleanup archives and manifests
temp/
cleanup_manifest.log
cleanup_scan_report.tsv

# Track capstone dependency specs and demo fixtures
!requirements/
!requirements/**/*.txt
!test_resources/demo/
!test_resources/demo/**/*.json
